apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ dra_gpu_namespace }}-privileged
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: system:openshift:scc:privileged
subjects:
  - kind: ServiceAccount
    name: default
    namespace: {{ dra_gpu_namespace }}
  - kind: ServiceAccount
    name: intel-gpu-sa
    namespace: {{ dra_gpu_namespace }}
