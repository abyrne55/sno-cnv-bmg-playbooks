---
# ── Change these for your environment ────────────────────────────

# Cluster identity
cluster_name: mycluster
base_domain: example.com

# Networking
machine_network_cidr: 192.168.1.0/24
rendezvous_ip: 192.168.1.100
gateway: 192.168.1.1
dns_servers:
  - 8.8.8.8
  - 8.8.4.4
ntp_sources:
  - pool.ntp.org

# Host
mac_address: "aa:bb:cc:dd:ee:ff"
nic_name: eno1
root_device: /dev/nvme0n1
serial_console: ttyS1,115200n8

# Disk partitioning
root_partition_size_mib: 204800  # 200G
virtstore_device: /dev/nvme0n1p5

# GPU
gpu_pci_id: "8086:e223"

# TLS (cert-manager / Let's Encrypt)
acme_email: user@example.com

# Auth
ssh_public_key: "ssh-rsa AAAA... user@example.com"

# ── Defaults (usually fine as-is) ───────────────────────────────

# Derived
hostname: "{{ cluster_name }}.{{ base_domain }}"
build_dir: "build/{{ cluster_name }}"

# OCP version
ocp_version: "4.22"
# Pinned: OCP 4.22 MCC only supports Ignition 3.5.0, but Butane 4.22.0 emits 3.6.0
butane_ocp_version: "4.21.0"

# Internal cluster networking
cluster_network_cidr: 10.128.0.0/14
cluster_network_host_prefix: 23
service_network_cidr: 172.30.0.0/16

# GPU
gpu_resource_name: devices.kubevirt.io/bmg-g31
gpu_driver_name: xe
gpu_access_mode: vfio  # vfio or dra

# Operator channels
lvms_channel: stable-4.21
cnv_channel: stable
certmanager_channel: stable-v1

# TLS
acme_server: https://acme-v02.api.letsencrypt.org/directory
cert_duration: 2160h   # 90d
cert_renew_before: 360h  # 15d

# VM
vm_name: rhel10-bmg
vm_namespace: bmg-vm
vm_cpus: 8
vm_memory: 32Gi
vm_disk_size: 60Gi
vm_source_image: rhel10
