---
exclude_paths:
  - vars/vault.yml

skip_list:
  - var-naming[no-role-prefix]
  - yaml[line-length]

# Vault-encrypted vars/vault.yml can't be decrypted during pre-commit,
# causing ansible-playbook --syntax-check to fail with internal-error.
# Individual role syntax checks still run fine.
warn_list:
  - internal-error
